.DS_Store
__pycache__/
*.py[cod]
.hub-launcher
.hub-slug
.hub-upstream
.hub-upstream-cache/
.hub-upgrade-staging/
sessions/bindings/
sessions/context/

# Session runtime — local only (_template + examples + _inbox/README committed)
sessions/*/
!sessions/_template/
!sessions/_inbox/
sessions/_inbox/*.md
!sessions/_inbox/README.md
sessions/index.json
sessions/_codenames.yaml
sessions/*/worktrees/*
repos/*
!repos/.gitkeep

repos.yaml
docs/PROJECT.md
*.code-workspace

# Local env / tooling
.env
.env.*
!.env.example
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
*.log

# Optional — uncomment when adding a Node monorepo (see CUSTOMIZE.md)
# node_modules/
# dist/
# *.tsbuildinfo
