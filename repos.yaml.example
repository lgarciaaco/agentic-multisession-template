# Product repo registry — paths relative to hub root.
# Agent: copy to repos.yaml and fill from user input (alias, clone URL, default_branch).
# Empty registry is valid — agent should ask the user before product work.

repos: {}

# Example (one repo):
# repos:
#   project:
#     path: repos/project
#     clone: git@github.com:YOU/PROJECT.git
#     default_branch: main
#
# Example (several repos):
#   immo-investor:
#     path: repos/immo-investor
#     clone: git@github.com:YOU/immo-investor.git
#     default_branch: main
#   flet-app:
#     path: repos/flet-app
#     clone: git@github.com:YOU/flet-app.git
#     default_branch: main
